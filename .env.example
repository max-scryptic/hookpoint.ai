NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Bypasses RLS to read/write the locked-down google_credentials
# table. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client (same client configured as the Supabase Google provider).
# Used server-side to exchange a user's refresh token for YouTube API access tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OpenAI Responses API credentials for transcript pacing analysis.
OPENAI_API_KEY=
# Optional model override. Defaults to gpt-5.4-mini.
OPENAI_PACING_MODEL=gpt-5.4-mini
# Exceptionally long videos are split when either limit is reached, then their
# chunk findings are synthesized into one video-wide analysis.
OPENAI_PACING_MAX_WINDOWS_PER_CALL=40
OPENAI_PACING_MAX_TRANSCRIPT_CHARS_PER_CALL=120000
# Limits simultaneous chunk requests. Defaults to 3.
OPENAI_PACING_MAX_PARALLEL_CHUNKS=3

# --- Raw source-file uploads (optional; sensible defaults shown) ---
# Object-storage bucket the raw video uploads land in (created by the
# source_files migration). Defaults to "source-files".
SOURCE_FILE_BUCKET=source-files
# Max accepted upload size in bytes. Default 30 GB (must be <= the bucket's
# file_size_limit). 32212254720 = 30 * 1024^3.
SOURCE_FILE_MAX_UPLOAD_BYTES=32212254720
# How many seconds the uploaded file's duration may differ from the YouTube
# value and still pass. Default 5.
SOURCE_FILE_DURATION_TOLERANCE_SECONDS=5
# Minimum filename/title similarity (0..1) below which we show the soft "doesn't
# match the title" warning. Default 0.3.
SOURCE_FILE_FILENAME_SIMILARITY_THRESHOLD=0.3
# --- Parallel multipart uploads (optional) ---
# When the four S3 connection values below are set, large uploads use a parallel
# multipart upload (many file parts PUT concurrently) instead of a single PUT,
# which lets a multi-GB upload actually saturate the user's uplink. Without them
# the app falls back to the single-PUT Supabase Storage client.
#
# Generate the access key + copy the endpoint/region from the Supabase dashboard:
# Project Settings → Storage → S3 connection (/dashboard/project/_/storage/s3).
# Use the *.storage.supabase.co host (not *.supabase.co) for faster large uploads.
#   ENDPOINT example: https://<project-ref>.storage.supabase.co/storage/v1/s3
# Notes for Supabase (vs. raw AWS S3 / R2):
#   • Incomplete multipart uploads are auto-aborted after 24h — no lifecycle rule
#     to configure. (On raw S3/R2 you'd add an AbortIncompleteMultipartUpload
#     lifecycle rule yourself, in the AWS S3 / Cloudflare R2 console.)
#   • Hosted Supabase Storage has no CORS settings to configure; the gateway
#     handles cross-origin responses. (On raw S3/R2 you must add a CORS rule that
#     exposes the ETag header, or the browser can't report part ETags.) If a real
#     multipart upload fails with a "missing ETag" error, the ETag isn't being
#     exposed and the fallback is a TUS resumable upload instead of presigned parts.
SOURCE_FILE_S3_ENDPOINT=
SOURCE_FILE_S3_REGION=
SOURCE_FILE_S3_ACCESS_KEY_ID=
SOURCE_FILE_S3_SECRET_ACCESS_KEY=
# Target size per part, in bytes. Default 64 MiB (67108864). The provider grows
# this automatically if needed to stay under S3's 10,000-part limit.
SOURCE_FILE_MULTIPART_PART_SIZE_BYTES=67108864
# Files at or above this size use multipart; smaller ones use a single PUT.
# Defaults to the part size.
SOURCE_FILE_MULTIPART_THRESHOLD_BYTES=67108864
# How long signed upload targets stay valid, in seconds. Default 6h (21600).
SOURCE_FILE_SIGNED_UPLOAD_EXPIRY_SECONDS=21600

# --- Video normalisation: 4K/original -> 1080p proxy via Qencode (optional) ---
# When this whole block is configured, a validated upload is handed to Qencode,
# which transcodes it to a 1080p H.264 proxy written back into the same bucket;
# once the proxy lands the (large) original is deleted and playback uses the
# proxy. Leave QENCODE_API_KEY unset to disable — uploads then keep the original
# exactly as before. Requires the S3 connection block above (the proxy is
# written via S3) and an APP_BASE_URL the Qencode callback can reach.
#
# Qencode account API key (Dashboard -> API -> API Key).
QENCODE_API_KEY=
# Optional API base override. Defaults to https://api.qencode.com/v1
QENCODE_API_BASE_URL=
# Proxy target height in px (aspect ratio preserved). Default 1080. Use 720 for
# smaller/cheaper proxies.
QENCODE_PROXY_HEIGHT=1080
# Optional extra Qencode `format` knobs as JSON, merged over the defaults, e.g.
# {"video_bitrate":"4000k","framerate":30}.
QENCODE_PROXY_FORMAT_OVERRIDES=
# How long the signed source URL handed to Qencode stays valid, seconds. Default
# 6h (21600) — must exceed how long Qencode may take to fetch a big original.
QENCODE_SOURCE_URL_EXPIRY_SECONDS=21600
# Public base URL of this app, used to build the status callback Qencode POSTs
# to (e.g. https://app.hookpoint.ai). On Vercel, VERCEL_URL is used as a
# fallback automatically.
APP_BASE_URL=
# Shared secret appended to the callback URL (?secret=...) and verified on the
# way back in, so the callback can't be forged. Generate a long random string.
QENCODE_CALLBACK_SECRET=
# Destination the proxy is written to. Each defaults to the SOURCE_FILE_S3_*
# / SOURCE_FILE_BUCKET values above, so you normally only set these to write the
# proxy somewhere different from the upload bucket/credentials.
#   HOST defaults to the host of SOURCE_FILE_S3_ENDPOINT.
QENCODE_DEST_S3_HOST=
QENCODE_DEST_S3_BUCKET=
QENCODE_DEST_S3_KEY=
QENCODE_DEST_S3_SECRET=
