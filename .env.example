NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Bypasses RLS to read/write the locked-down google_credentials
# table. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client (same client configured as the Supabase Google provider).
# Used server-side to exchange a user's refresh token for YouTube API access tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server-only. Enables the AI insights layer (hook score + per-drop hypotheses).
# With no key set, analyses still work — the "Generate AI insights" button is
# simply disabled. Never expose to the browser.
OPENAI_API_KEY=
# Optional: override the insights model (defaults to gpt-4o). Use gpt-4o-mini
# for ~10x cheaper calls at some cost to reasoning quality.
OPENAI_INSIGHTS_MODEL=

# Optional. Residential proxy used ONLY for the YouTube storyboard spec request,
# which YouTube bot-challenges from datacenter IPs (so on-screen frames never get
# captured in production without it). Format: http://user:pass@host:port
# Unset = frames are skipped and insights run transcript-only, exactly as before.
#
# IMPORTANT: the proxy's exit IP must be geo-located in the US (the request asks
# YouTube for gl=US). A non-US or region-mismatched exit makes even public videos
# come back as UNPLAYABLE "Video unavailable" and no frames are captured. Most
# residential providers target a country via username flags, e.g.
#   http://USER-country-us:PASS@gate.provider.com:7777
# Check your provider's docs for the exact sticky-US-session syntax.
STORYBOARD_PROXY_URL=
