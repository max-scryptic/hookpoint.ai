NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Server-only. Bypasses RLS to read/write the locked-down google_credentials
# table. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Google OAuth client (same client configured as the Supabase Google provider).
# Used server-side to exchange a user's refresh token for YouTube API access tokens.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server-only. Enables the AI insights layer (hook score + per-drop hypotheses).
# With no key set, analyses still work — the "Generate AI insights" button is
# simply disabled. Never expose to the browser.
OPENAI_API_KEY=
# Optional: override the insights model (defaults to gpt-4o). Use gpt-4o-mini
# for ~10x cheaper calls at some cost to reasoning quality.
OPENAI_INSIGHTS_MODEL=
